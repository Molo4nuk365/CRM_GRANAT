{
  // Секция со строками подключения к базам данных
  "ConnectionStrings": {
    // Строка подключения к основной базе данных CRM
    // Server - имя локального экземпляра SQL Server Express
    // Database - имя БД (будет создана автоматически при миграциях)
    // Trusted_Connection=True - использовать Windows-аутентификацию
    // Encrypt=True, TrustServerCertificate=True - шифрование с самоподписанным сертификатом (для разработки)
    // MultipleActiveResultSets=true - разрешает несколько активных наборов результатов на одно соединение
    "DefaultConnection": "Server=LAPTOP-QU8TEID8\\SQLEXPRESS02;Database=CRM_Jewelry_workshop;Trusted_Connection=True;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },

  // Секция с настройками JWT-аутентификации
  "Jwt": {
    // Секретный ключ для подписи JWT-токенов (должен быть минимум 32 символа)
    "Key": "supersecretkeywithatleast32characterslong!",
    // Издатель токена (iss) – кто выпустил токен
    "Issuer": "JewelryCRM",
    // Аудитория (aud) – для кого предназначен токен (обычно клиентское приложение)
    "Audience": "JewelryClient"
  },

  // Секция настройки логирования
  "Logging": {
    // Уровни логирования для разных категорий
    "LogLevel": {
      // По умолчанию выводить информационные сообщения и выше (Information, Warning, Error, Critical)
      "Default": "Information",
      // Для пространства имен Microsoft.AspNetCore – только предупреждения и ошибки (меньше шума)
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // Разрешить любые хосты (для CORS и ограничений хоста)
  // "*" означает – запросы с любых доменов принимаются
  "AllowedHosts": "*"
}
