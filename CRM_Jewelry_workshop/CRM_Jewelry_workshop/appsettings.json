{
  // Строка подключения к SQLite: файл будет храниться в папке Data
  "ConnectionStrings": {
    "CRM_Jewelry_workshop": "Data Source=.\\Data\\SQlLiteDatabase.db"
  },

  // Настройки JWT-токенов
  "Jwt": {
    "Key": "supersecretkeywithatleast32characterslong!", // Ключ шифрования (не менее 32 символов)
    "Issuer": "JewelryCRM", // Издатель токена (кто выпустил)
    "Audience": "JewelryClient" // Получатель (кто может использовать токен)
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information", // Информационные сообщения
      "Microsoft.AspNetCore": "Warning" // Только предупреждения от ASP.NET
    }
  },

  "AllowedHosts": "*" // Разрешаем запросы с любых источников (для CORS)
}